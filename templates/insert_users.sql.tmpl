INSERT INTO {{ .Schema }}.{{ .TableName }} (
    id,
    email,
    name,
    created_at,
    updated_at
)
VALUES
{{- range $i, $row := .Rows }}
    {{- if $i }},{{ end }}
    ({{ $row }})
{{- end }}
ON CONFLICT (id)
DO UPDATE SET
    email = EXCLUDED.email,
    name = EXCLUDED.name,
    updated_at = EXCLUDED.updated_at;
